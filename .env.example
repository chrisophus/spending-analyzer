# Optional — only needed for the LLM-assisted pass (--no-llm skips it entirely).
# The analyzer works fully offline without this; the LLM only adds merchant
# identification ("what is BOING US HOLDCO?") and discretionary/essential
# judgement for uncategorized charges.
ANTHROPIC_API_KEY=sk-ant-...

# Optional model override (defaults to a current Claude model).
# ANALYZER_MODEL=claude-sonnet-4-6
